    "usability.html": {
      "settings": {
        "meta_descr": "Sarava's design team has worked hard to prepare an E-commerce Usability Report; a complete report of category pages, product pages, home page, checkout, delivery, payment methods, customer support, search, search results, forms, and user flows.",
        "title": "SARAVA USABILITY PAGE  —  BMDX",
