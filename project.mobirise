        "meta_descr": "“Cheragh”  is a job portal system (startup) at early stages that connects candidates who are looking for a job with the opportunities that suit them best. It also offers a wide variety of educational contents and personality tests.",
        "title": "CHERAGH  —  BMDX",
        "order": 4,
        "meta_image": "@PROJECT_PATH@/assets/images/cheragh.jpg"
      },
