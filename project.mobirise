    "about.html": {
      "settings": {
        "meta_descr": "I am mobin bahrami, a creative problem solver or in other words a multidisciplinary designer for creating products and services with usable, useful and user-friendly features, with a thorough mix of design, technical abilities and business ideas, as well as formulated design solutions.",
        "title": "ABOUT  —  BMDX",
        "order": 1,
        "meta_image": "@PROJECT_PATH@/assets/images/about-4.jpg"
      },
      "components": [
        {
          "_styles": {
            ".navbar": {
              "padding": ".5rem 0",
              "background": "@menuBgColor",
